---
export interface Props {
  title?: string;
  activeNav?: string;
}
const { title = 'Ducspace', activeNav = 'readme' } = Astro.props;
import { getCollection } from 'astro:content';
let allTags: string[] = [];
try {
  const notes = await getCollection('notes');
  const tagSet = new Set<string>();
  notes.forEach(n => n.data.tags?.forEach((t: string) => tagSet.add(t)));
  allTags = Array.from(tagSet).sort();
} catch(e) {}
const workTags = ['aftersales', 'system thinking', 'ai', 'automotive', 'management'];
---
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <div class="app-shell">
    <!-- SIDEBAR (desktop only) -->
    <aside class="sidebar" id="sidebar">
      <!-- Logo + Avatar -->
      <a href="/" class="logo" style="text-decoration:none;">
        <img
          src="https://avatars.githubusercontent.com/u/258771193?v=4"
          alt="Duc"
          class="logo-avatar"
        />
        <span class="logo-text">
          <span class="logo-duc">Duc</span><span class="logo-cursor"></span><span class="logo-space">space</span>
        </span>
      </a>

      <div class="sidebar-divider"></div>

      <!-- Nav -->
      <nav>
        <ul class="nav-menu">
          <li><a href="/" class={activeNav === 'readme' ? 'active' : ''}>readme</a></li>
          <li><a href="/notes" class={activeNav === 'notes' ? 'active' : ''}>notes</a></li>
          <li><a href="/photos" class={activeNav === 'photos' ? 'active' : ''}>photos</a></li>
          <li><a href="/bookmarks" class={activeNav === 'bookmarks' ? 'active' : ''}>bookmarks</a></li>
        </ul>
      </nav>

      <div class="sidebar-divider"></div>

      <!-- Tags -->
      {allTags.length > 0 && (
        <>
          <div class="sidebar-label">Tags</div>
          <ul class="sidebar-tags">
            {allTags.map(tag => (
              <li><a href={`/notes?tag=${encodeURIComponent(tag)}`}>#{tag}</a></li>
            ))}
          </ul>
          <div class="sidebar-divider"></div>
        </>
      )}

      <!-- Connect -->
      <div class="sidebar-label">Connect</div>
      <ul class="connect-links">
        <li>
          <a href="mailto:Duclc93@gmail.com">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>
            email
          </a>
        </li>
        <li>
          <a href="https://github.com/ducspace" target="_blank" rel="noopener">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
            github
          </a>
        </li>
        <li>
          <a href="https://fb.com/duclc93" target="_blank" rel="noopener">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            facebook
          </a>
        </li>
      </ul>

      <!-- Bottom controls -->
      <div class="sidebar-bottom">
        <div class="sidebar-divider"></div>
        <button class="dark-toggle" id="darkToggle" aria-label="Toggle dark mode">
          <span>dark mode</span>
          <span class="toggle-pill"></span>
        </button>
      </div>
    </aside>

    <!-- CONTENT -->
    <main class="content">
      <slot />
    </main>
  </div>

  <!-- MOBILE HEADER (mobile only) -->
  <header class="mobile-header" id="mobileHeader">
    <a href="/" class="mobile-logo" style="text-decoration:none;">
      <img
        src="https://avatars.githubusercontent.com/u/258771193?v=4"
        alt="Duc"
        class="mobile-logo-avatar"
      />
      <span class="mobile-logo-text">
        <span class="logo-duc">Duc</span><span class="logo-cursor"></span><span class="logo-space">space</span>
      </span>
    </a>
    <button class="mobile-dark-toggle" id="mobileDarkToggle" aria-label="Toggle dark mode">
      <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
      <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="3"/>
        <line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/>
        <line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
    </button>
  </header>

  <!-- BOTTOM NAV BAR (mobile only) -->
  <nav class="bottom-nav" id="bottomNav" aria-label="Mobile navigation">
    <a href="/" class={`bottom-nav-item ${activeNav === 'readme' ? 'active' : ''}`}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      <span>readme</span>
    </a>
    <a href="/notes" class={`bottom-nav-item ${activeNav === 'notes' ? 'active' : ''}`}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
      </svg>
      <span>notes</span>
    </a>
    <a href="/photos" class={`bottom-nav-item ${activeNav === 'photos' ? 'active' : ''}`}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
        <circle cx="8.5" cy="8.5" r="1.5"/>
        <polyline points="21 15 16 10 5 21"/>
      </svg>
      <span>photos</span>
    </a>
    <a href="/bookmarks" class={`bottom-nav-item ${activeNav === 'bookmarks' ? 'active' : ''}`}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
      </svg>
      <span>bookmarks</span>
    </a>
  </nav>

  <script>
    // ── Dark mode ──
    const toggleDesktop = document.getElementById('darkToggle');
    const toggleMobile  = document.getElementById('mobileDarkToggle');
    const html = document.documentElement;

    const saved = localStorage.getItem('theme');
    if (saved) html.setAttribute('data-theme', saved);

    function applyTheme(theme: string) {
      html.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
    }

    toggleDesktop?.addEventListener('click', () => {
      const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      applyTheme(next);
    });

    toggleMobile?.addEventListener('click', () => {
      const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      applyTheme(next);
    });

    // ── Scroll hide/show header & bottom nav ──
    const mobileHeader = document.getElementById('mobileHeader');
    const bottomNav    = document.getElementById('bottomNav');

    let lastScrollY = window.scrollY;
    let ticking = false;

    function onScroll() {
      const currentY = window.scrollY;
      const diff = currentY - lastScrollY;

      if (diff > 4) {
        // Scrolling DOWN → hide both bars
        mobileHeader?.classList.add('bars-hidden');
        bottomNav?.classList.add('bars-hidden');
      } else if (diff < -4) {
        // Scrolling UP → show both bars
        mobileHeader?.classList.remove('bars-hidden');
        bottomNav?.classList.remove('bars-hidden');
      }

      lastScrollY = currentY;
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(onScroll);
        ticking = true;
      }
    }, { passive: true });
  </script>
</body>
</html>
